{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/biomed-research-integrity-auditor/audit_summary.schema.json",
  "title": "Audit JSON Summary",
  "type": "object",
  "required": [
    "audit_mode",
    "materials_reviewed",
    "materials_missing",
    "overall_risk",
    "misconduct_verdict_present",
    "risk_caps_applied",
    "positive_provenance",
    "traceability_gaps",
    "findings"
  ],
  "properties": {
    "audit_mode": {"type": "string"},
    "case_id": {"type": ["string", "null"]},
    "materials_reviewed": {"type": "array", "items": {"type": "string"}},
    "materials_missing": {"type": "array", "items": {"type": "string"}},
    "overall_risk": {"enum": ["R0", "R1", "R2", "R3", "R4"]},
    "misconduct_verdict_present": {"type": "boolean"},
    "risk_caps_applied": {"type": "array", "items": {"type": "string"}},
    "positive_provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "provenance_id",
          "relation_type",
          "figure_panel",
          "source_record",
          "evidence_source",
          "risk_effect"
        ],
        "properties": {
          "provenance_id": {"type": "string"},
          "relation_type": {"type": "string"},
          "figure_panel": {"type": "string"},
          "source_record": {"type": "string"},
          "evidence_source": {"type": "string"},
          "risk_effect": {"type": "string"}
        }
      }
    },
    "traceability_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "gap_id",
          "finding_type",
          "risk_level",
          "required_materials_to_resolve"
        ],
        "properties": {
          "gap_id": {"type": "string"},
          "finding_type": {"type": "string"},
          "risk_level": {"enum": ["R0", "R1", "R2", "R3", "R4"]},
          "location": {"type": "string"},
          "required_materials_to_resolve": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "risk_level",
          "finding_type",
          "location",
          "evidence_type",
          "benign_explanations_considered",
          "required_materials_to_resolve",
          "recommended_action"
        ],
        "properties": {
          "finding_id": {"type": "string"},
          "risk_level": {"enum": ["R0", "R1", "R2", "R3", "R4"]},
          "finding_type": {"type": "string"},
          "location": {"type": "string"},
          "evidence_type": {"type": "string"},
          "benign_explanations_considered": {"type": "array", "items": {"type": "string"}},
          "required_materials_to_resolve": {"type": "array", "items": {"type": "string"}},
          "recommended_action": {"type": "string"}
        }
      }
    },
    "claim_coverage": {
      "type": "object",
      "properties": {
        "supplied": {"type": "boolean"},
        "claim_manifest": {"type": ["string", "null"]},
        "claims_declared": {"type": "integer"},
        "claims_with_source_data": {"type": "integer"},
        "claims_with_raw_records": {"type": "integer"},
        "claims_with_analysis_code": {"type": "integer"},
        "claims_with_protocol_link": {"type": "integer"},
        "claims_with_unresolved_evidence_gap": {"type": "integer"},
        "unresolved_claims": {"type": "array"},
        "scope_note": {"type": "string"}
      }
    },
    "methodology_checklist": {
      "type": "object",
      "required": ["version", "scope", "requested_domains", "modules", "totals", "boundary_note"],
      "properties": {
        "version": {"type": "string"},
        "scope": {"type": "string"},
        "requested_domains": {"type": "array", "items": {"type": "string"}},
        "boundary_note": {"type": "string"},
        "boundary_note_zh": {"type": "string"},
        "totals": {
          "type": "object",
          "properties": {
            "modules_requested": {"type": "integer"},
            "checks_ready_for_manual_review": {"type": "integer"},
            "checks_partial_supporting_materials": {"type": "integer"},
            "checks_missing_supporting_materials": {"type": "integer"},
            "checks_not_requested": {"type": "integer"}
          }
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["module_id", "label_en", "label_zh", "standard", "requested", "status", "checks"],
            "properties": {
              "module_id": {"type": "string"},
              "label_en": {"type": "string"},
              "label_zh": {"type": "string"},
              "standard": {"type": "string"},
              "domains": {"type": "array", "items": {"type": "string"}},
              "requested": {"type": "boolean"},
              "status": {"type": "string"},
              "checks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "check_id",
                    "label_en",
                    "label_zh",
                    "status",
                    "supporting_material_categories",
                    "supplied_material_categories",
                    "missing_material_categories",
                    "recommended_action_en",
                    "recommended_action_zh"
                  ],
                  "properties": {
                    "check_id": {"type": "string"},
                    "label_en": {"type": "string"},
                    "label_zh": {"type": "string"},
                    "status": {"type": "string"},
                    "supporting_material_categories": {"type": "array", "items": {"type": "string"}},
                    "supplied_material_categories": {"type": "array", "items": {"type": "string"}},
                    "missing_material_categories": {"type": "array", "items": {"type": "string"}},
                    "supplied_files": {"type": "object"},
                    "recommended_action_en": {"type": "string"},
                    "recommended_action_zh": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
