{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/biomed-research-integrity-auditor/audit_summary.schema.json",
  "title": "Audit JSON Summary",
  "type": "object",
  "required": [
    "audit_mode",
    "materials_reviewed",
    "materials_missing",
    "overall_risk",
    "misconduct_verdict_present",
    "risk_caps_applied",
    "positive_provenance",
    "traceability_gaps",
    "findings"
  ],
  "properties": {
    "audit_mode": {"type": "string"},
    "case_id": {"type": ["string", "null"]},
    "materials_reviewed": {"type": "array", "items": {"type": "string"}},
    "materials_missing": {"type": "array", "items": {"type": "string"}},
    "overall_risk": {"enum": ["R0", "R1", "R2", "R3", "R4"]},
    "misconduct_verdict_present": {"type": "boolean"},
    "risk_caps_applied": {"type": "array", "items": {"type": "string"}},
    "positive_provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "provenance_id",
          "relation_type",
          "figure_panel",
          "source_record",
          "evidence_source",
          "risk_effect"
        ],
        "properties": {
          "provenance_id": {"type": "string"},
          "relation_type": {"type": "string"},
          "figure_panel": {"type": "string"},
          "source_record": {"type": "string"},
          "evidence_source": {"type": "string"},
          "risk_effect": {"type": "string"}
        }
      }
    },
    "traceability_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "gap_id",
          "finding_type",
          "risk_level",
          "required_materials_to_resolve"
        ],
        "properties": {
          "gap_id": {"type": "string"},
          "finding_type": {"type": "string"},
          "risk_level": {"enum": ["R0", "R1", "R2", "R3", "R4"]},
          "location": {"type": "string"},
          "required_materials_to_resolve": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "risk_level",
          "finding_type",
          "location",
          "evidence_type",
          "benign_explanations_considered",
          "required_materials_to_resolve",
          "recommended_action"
        ],
        "properties": {
          "finding_id": {"type": "string"},
          "risk_level": {"enum": ["R0", "R1", "R2", "R3", "R4"]},
          "finding_type": {"type": "string"},
          "location": {"type": "string"},
          "evidence_type": {"type": "string"},
          "benign_explanations_considered": {"type": "array", "items": {"type": "string"}},
          "required_materials_to_resolve": {"type": "array", "items": {"type": "string"}},
          "recommended_action": {"type": "string"}
        }
      }
    }
  }
}
